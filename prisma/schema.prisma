// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  
}

// =========================
// ENUMS
// =========================

enum Role {
  ADMIN
  HOST
  GUEST
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

// =========================
// MODELS
// =========================

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  username         String    @unique
  phone            String
  password         String
  role             Role      @default(GUEST)
  avatar           String?
  bio              String?
  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings Listing[]
  bookings Booking[]
  reviews  Review[]

  @@index([name])
  @@index([role])
}

model Listing {
  id String @id @default(uuid())

  title       String
  description String
  location    String

  pricePerNight Float
  guests        Int

  type      ListingType
  amenities String[]

  rating Float?
    // Images
  image    String?
  imageUrl String?
  images   String[]


  // Admin moderation
  status          ListingStatus @default(PENDING)
  rejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  host   User   @relation(fields: [hostId], references: [id])
  hostId String

  bookings Booking[]
  reviews  Review[]

  @@index([location])
  @@index([pricePerNight])
  @@index([type])
  @@index([hostId])
  @@index([status])
  @@index([type, location])
}

model Booking {
  id String @id @default(uuid())

  checkIn  DateTime
  checkOut DateTime

  guests     Int   @default(1)
  totalPrice Float

  status BookingStatus @default(PENDING)

  createdAt DateTime @default(now())

  // Relations
  guest   User   @relation(fields: [guestId], references: [id])
  guestId String

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String

  @@index([guestId])
  @@index([listingId])
  @@index([listingId, checkIn, checkOut])
  @@index([status])
}

model Review {
  id String @id @default(uuid())

  rating  Int
  comment String

  createdAt DateTime @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  userId String

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String

  @@index([userId])
  @@index([listingId])
}
